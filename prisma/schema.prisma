generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Template {
  id         String      @id @default(uuid())
  name       String
  canvasJson Json        @map("canvas_json")
  pageSize   String      @default("A4") @map("page_size")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  exportJobs ExportJob[]

  @@map("templates")
}

model DataSource {
  id            String       @id @default(uuid())
  name          String
  // stored AES-256-GCM encrypted — always use lib/encrypt.ts to read/write
  connectionUrl String       @map("connection_url")
  createdAt     DateTime     @default(now()) @map("created_at")
  savedQueries  SavedQuery[]

  @@map("data_sources")
}

model SavedQuery {
  id           String     @id @default(uuid())
  name         String
  sql          String
  dataSourceId String     @map("data_source_id")
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("saved_queries")
}

model WebhookConfig {
  id             String   @id @default(uuid())
  inboundSecret  String   @map("inbound_secret")
  outboundUrl    String?  @map("outbound_url")
  outboundSecret String?  @map("outbound_secret")
  outboundEvents String[] @map("outbound_events")

  @@map("webhook_configs")
}

enum ExportFormat {
  pdf
  image
  docx
}

enum ExportStatus {
  pending
  done
  failed
}

model ExportJob {
  id          String       @id @default(uuid())
  templateId  String       @map("template_id")
  template    Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  recordId    String       @map("record_id")
  format      ExportFormat
  status      ExportStatus @default(pending)
  filePath    String?      @map("file_path")
  triggeredBy String       @default("ui") @map("triggered_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("export_jobs")
}

model LicenseApplicant {
  id               String               @id @default(uuid())
  fullname         String
  nokp             String               @unique
  namaPerniagaan   String               @map("nama_perniagaan")
  lokasiPerniagaan String               @map("lokasi_perniagaan")
  phoneNumber      String?              @map("phone_number")
  isActive         Boolean              @default(true) @map("is_active")
  createdAt        DateTime             @default(now()) @map("created_at")
  applications     LicenseApplication[]

  @@map("license_applicants")
}

model LicenseApplication {
  id                String           @id @default(uuid())
  applicantId       String           @map("applicant_id")
  applicant         LicenseApplicant @relation(fields: [applicantId], references: [id])
  district          String
  entertainmentType String           @map("entertainment_type")
  status            String           @default("DALAM_PROSES")
  documents         Json             @default("[]")
  remarks           Json             @default("[]")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("license_applications")
}

// Multi-source data block configuration for templates
model DataBlock {
  id               String            @id @default(uuid())
  templateId       String            @map("template_id")
  name             String            @map("name")
  primarySourceId  String            @unique @map("primary_source_id")
  primarySource    PrimarySource     @relation(fields: [primarySourceId], references: [id], onDelete: Cascade)
  secondarySources SecondarySource[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@map("data_blocks")
}

model PrimarySource {
  id          String     @id @default(uuid())
  sourceId    String     @map("source_id")
  type        String     @map("type") // "table" | "query"
  tableName   String?    @map("table_name")
  query       String?    @map("query")
  dataBlockId String     @map("data_block_id")
  dataBlock   DataBlock?

  @@map("primary_sources")
}

model SecondarySource {
  id          String    @id @default(uuid())
  alias       String    @map("alias") // e.g., "check", "applicant"
  sourceId    String    @map("source_id")
  type        String    @map("type") // "table" | "query"
  tableName   String?   @map("table_name")
  query       String?   @map("query")
  joinKey     String    @map("join_key") // field to match with primary (e.g., "nokp")
  dataBlockId String    @map("data_block_id")
  dataBlock   DataBlock @relation(fields: [dataBlockId], references: [id])

  @@map("secondary_sources")
}
